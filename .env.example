# Zolara environment template
# Copy to .env locally. Do not commit real secrets.

NODE_ENV=development
PORT=3000

# Telegram bots
ZOLARA_BOT_TOKEN=replace_me
MANAGED_BOTS_TOKEN=replace_me
WEBHOOK_SECRET=replace_me_min_32_chars

# Webhooks
# For testers/prod, use a stable HTTPS hostname, not random trycloudflare.com.
WEBHOOK_BASE_URL=https://your-stable-host.example.com
ZOLARA_HOSTING_MODE=cloudflare
ZOLARA_TUNNEL_NAME=zolara-prod

# Database / Redis
DATABASE_URL=postgres://user:password@localhost:5432/zolara
REDIS_URL=redis://localhost:6379

# LLM / crypto
MINIMAX_API_KEY=replace_me
ENCRYPTION_KEY=replace_me_32_byte_base64_or_hex
